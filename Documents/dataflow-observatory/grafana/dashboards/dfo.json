{
  "uid": "dfo-main",
  "title": "DataFlow Observatory",
  "description": "Real-time data quality monitoring — events, alerts, quality scores",
  "tags": ["dataflow", "kafka", "dq"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 39,

  "templating": {
    "list": [
      {
        "name": "source",
        "label": "Source",
        "type": "query",
        "datasource": { "uid": "prometheus", "type": "prometheus" },
        "query": "label_values(dfo_quality_score, source)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Quality Score — Clickstream",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0   },
              { "color": "yellow", "value": 0.8 },
              { "color": "green",  "value": 0.95 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "dfo_quality_score{source=\"clickstream\"}",
          "legendFormat": "Clickstream"
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Quality Score — IoT Sensor",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0    },
              { "color": "yellow", "value": 0.8  },
              { "color": "green",  "value": 0.95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "dfo_quality_score{source=\"iot_sensor\"}",
          "legendFormat": "IoT Sensor"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Events Last Hour",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "targets": [
        {
          "expr": "sum(dfo_total_events)",
          "legendFormat": "Total Events"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Redis Alert Queue",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0    },
              { "color": "yellow", "value": 1000 },
              { "color": "red",    "value": 5000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "dfo_redis_alert_queue_size",
          "legendFormat": "Queue depth"
        }
      ]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Quality Score Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0    },
              { "color": "yellow", "value": 0.8  },
              { "color": "green",  "value": 0.95 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "clickstream" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          },
          {
            "matcher": { "id": "byName", "options": "iot_sensor" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "dfo_quality_score{source=~\"$source\"}",
          "legendFormat": "{{source}}"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Alert Rate by Severity",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1, "fillOpacity": 20 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*critical.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*high.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*medium.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (severity) (dfo_alert_count{source=~\"$source\"})",
          "legendFormat": "{{severity}}"
        }
      ]
    },

    {
      "id": 7,
      "type": "barchart",
      "title": "Alerts by Type",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "list", "placement": "right" },
        "tooltip": { "mode": "single" },
        "xTickLabelRotation": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "sum by (alert_type) (dfo_alert_count{source=~\"$source\"})",
          "legendFormat": "{{alert_type}}",
          "instant": true
        }
      ]
    },

    {
      "id": 8,
      "type": "barchart",
      "title": "Null Rates by Field",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "list", "placement": "right" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0    },
              { "color": "yellow", "value": 0.02 },
              { "color": "red",    "value": 0.05 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "dfo_null_rate{source=~\"$source\"}",
          "legendFormat": "{{source}} / {{field}}",
          "instant": true
        }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Dirty Event % Over Time",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0    },
              { "color": "yellow", "value": 0.02 },
              { "color": "red",    "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "dfo_dirty_events{source=~\"$source\"} / dfo_total_events{source=~\"$source\"}",
          "legendFormat": "{{source}}"
        }
      ]
    },

    {
      "id": 10,
      "type": "gauge",
      "title": "Ingest Lag (seconds)",
      "gridPos": { "x": 12, "y": 20, "w": 6, "h": 6 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0, "max": 60,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0  },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 30 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg by (source) (dfo_ingest_lag_seconds{source=~\"$source\"})",
          "legendFormat": "{{source}}"
        }
      ]
    },

    {
      "id": 11,
      "type": "piechart",
      "title": "Alert Distribution by Source",
      "gridPos": { "x": 18, "y": 20, "w": 6, "h": 6 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent"] },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "sum by (source) (dfo_alert_count)",
          "legendFormat": "{{source}}",
          "instant": true
        }
      ]
    }

  ]
}
