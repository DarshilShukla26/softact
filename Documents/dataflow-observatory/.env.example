# Copy to .env and fill in your Snowflake free-trial credentials.
# Then run:  source .env  (before dbt run / go services)

# Snowflake account identifier — found in your trial welcome email.
# Format: <orgname>-<accountname>  OR  <locator>.<region>  e.g. abc12345.us-east-1
export SNOWFLAKE_ACCOUNT=your-account-here

# The user you created during Snowflake sign-up (usually your email username)
export SNOWFLAKE_USER=your-user-here

export SNOWFLAKE_PASSWORD=your-password-here
